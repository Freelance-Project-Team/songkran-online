generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum OAuthProvider {
    GOOGLE
    LINE
    FACEBOOK
}

model User {
    id         Int            @id @default(autoincrement())
    email      String?        @unique
    name       String?
    avatar     String?
    password   String?
    provider   OAuthProvider?
    providerId String?
    createdAt  DateTime       @default(now())
    updatedAt  DateTime       @updatedAt

    participations ActivityParticipant[]
    accessLogs     ActivityAccessLog[]
    waterPlayLogs  WaterPlayLog[]

    @@unique([provider, providerId])
}

model Activity {
    id          Int      @id @default(autoincrement())
    name        String
    description String?
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    participants ActivityParticipant[]
    accessLogs   ActivityAccessLog[]
}

model ActivityParticipant {
    id         Int      @id @default(autoincrement())
    userId     Int
    activityId Int
    joinedAt   DateTime @default(now())

    user     User     @relation(fields: [userId], references: [id])
    activity Activity @relation(fields: [activityId], references: [id])

    @@unique([userId, activityId])
}

model ActivityAccessLog {
    id         Int      @id @default(autoincrement())
    userId     Int?
    activityId Int
    ip         String?
    userAgent  String?
    createdAt  DateTime @default(now())

    user     User?    @relation(fields: [userId], references: [id])
    activity Activity @relation(fields: [activityId], references: [id])
}

model WaterPlayLog {
    id         Int      @id @default(autoincrement())
    userId     Int?
    character  String
    locationId String
    ip         String?
    userAgent  String?
    createdAt  DateTime @default(now())

    user User? @relation(fields: [userId], references: [id])
}
